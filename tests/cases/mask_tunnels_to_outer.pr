-- `mask<E>` tunnels `op` past `f`'s own handler to the outer handler in `main`,
-- which resumes with `x + 100`, so `f : () -> Int !{E}` and the program prints
-- 101. Regression: the masked effect must stay in `f`'s row, not be discharged.
effect E
  op(Int) : Int

fn f() =
  handle mask<E>(op(1)) with
    op(x) resume k => k(x)
    return r => r

fn main() : Unit ! {IO} =
  let r =
    handle f() with
      op(x) resume k => k(x + 100)
      return r => r
  println(r)
