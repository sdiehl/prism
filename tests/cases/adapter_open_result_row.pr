-- The essential adapter type is polymorphic in the ambient tail `e`: it removes
-- its source protocol, introduces its target protocol, and forwards the rest of
-- the row untouched. That open result row can be spelled explicitly as a
-- declaration annotation (`: a ! {KvV2 | e}`): an effect-forwarding runner may
-- name the row it forwards rather than eliding the `!` and leaving ambient
-- preservation implicit. The row still stays inferred; the annotation documents
-- and checks the introduced protocol.
effect KvV1
  get_v1(Int) : Int
  put_v1(Int, Int) : Unit

effect KvV2
  get_v2(Int) : Int
  put_v2(Int, Int) : Unit

fn adapt_v1_to_v2(action : () -> a ! {KvV1 | e}) : a ! {KvV2 | e} =
  handle action() with
    get_v1(key) resume k => k(get_v2(key))
    put_v1(key, value) resume k =>
      put_v2(key, value)
      k(())
    return r => r
