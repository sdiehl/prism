effect Exn
  raise(Int) : Int

effect Ask
  ask() : Int

effect State
  get() : Int
  put(Int) : Unit

fn catch_exn() =
  handle raise(42) with
    raise(v) resume k => v
    return r => r

fn ask_example() =
  handle ask() with
    ask() resume k => k(99)
    return r => r

fn state_example() =
  handle let a = get() in let _ = put(a + 1) in get() with
    get() resume k => k(10)
    put(v) resume k => k(())
    return r => r

fn main() =
  let a = catch_exn()
  let b = ask_example()
  let c = state_example()
  println(a + b + c)
