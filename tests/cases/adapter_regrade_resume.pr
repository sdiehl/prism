-- An adapter clause must obey the source operation's resumption grade. A `once`
-- source operation resumes exactly once; a clause that resumes it twice regrades
-- the operation, which is rejected as an ordinary grade violation at the clause.
effect KvV1
  once get_v1(Int) : Int
  put_v1(Int, Int) : Unit

effect KvV2
  get_v2(Int) : Int
  put_v2(Int, Int) : Unit

fn adapt_regrades(action) =
  handle action() with
    get_v1(key) resume k => k(get_v2(key)) + k(0)
    put_v1(key, value) resume k =>
      put_v2(key, value)
      k(())
    return r => r

fn client_v1() : Int ! {KvV1} =
  put_v1(1, 100)
  get_v1(1)
