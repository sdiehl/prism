-- `without alloc <block>` asserts a region allocates no fresh heap cell. Desugar
-- lifts the block to a synthetic top-level `without alloc` function capturing its
-- free locals (`base`), so the whole-call-tree check covers exactly the region.
fn tick(n : Int) : Int =
  let base = n + 1
  without alloc base + base

fn main() : Int = tick(20)
