-- The absorption fix, as a rejection: `wrap` is an UNPARAMETERIZED effect op
-- taking a thunk with an open row `{Wrap | e}`. The thunk `body` performs `Beep`,
-- so `Beep` must flow out through the perform site into `use_wrap`'s row. The
-- annotation omits it, so this is now correctly rejected (before the fix the
-- thunk's row was dropped on an unparameterized effect, and only a phantom type
-- parameter forced the absorption).
effect Beep
  beep(Int) : Unit

effect Wrap
  wrap(() -> Int ! {Wrap | e}) : Int

fn body() : Int ! {Wrap, Beep} =
  beep(1)
  3

fn use_wrap() : Int ! {Wrap} = wrap(body)
