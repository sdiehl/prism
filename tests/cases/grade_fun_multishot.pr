-- A `fun` operation (grade One) resumes exactly once. A bare-ctl clause that
-- resumes `poll` twice exceeds the declared grade and is rejected.
effect Poll
  fun poll(Unit) : Int

fn use_it() : !{Poll} Int = poll(())

fn main() =
  handle use_it() with
    poll(u, k) => k(1) + k(2)
    return r => r
