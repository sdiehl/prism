-- A `never` operation (grade Never) may not be resumed. Handling `abort`
-- with a resuming `once` clause is rejected at the clause, naming the op grade.
effect Abort
  never abort(Unit) : Int

fn use_it() : Int ! {Abort} = abort(())

fn main() =
  handle use_it() with
    once abort(u) => 5
    return r => r
