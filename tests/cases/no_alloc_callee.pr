-- The certificate covers the whole call tree: an `@ noalloc` function may
-- call only `fip`/`fbip`/`@ noalloc` functions. `top` calls `mk`, which is
-- unannotated and allocates, so `top`'s guarantee cannot be trusted.
type Box = Box(Int)

fn mk(x : Int) : Box = Box(x)

fn top(x : Int) : Box @ noalloc = mk(x)
