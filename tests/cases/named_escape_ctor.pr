-- A named handler instance must not escape inside a data value. The tuple would
-- carry a closure performing `f`'s private op out of `f`'s `with` block.
effect Ask
  ctl ask() : Int

fn leak() : (Unit, (Unit) -> Int) =
  with f <- handler
    ask(k) => k(5)
    return r => r
  ((), \(u) -> f.ask())

fn main() = println(0)
