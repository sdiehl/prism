-- A named handler instance must not escape through another effect's operation
-- payload. The closure carries `f`'s private op, so it leaks past `f`'s handler
-- when `save`'s handler eventually runs it: the unhandled-effect wall catches it
-- and names the instance rather than the mangled internal effect.
effect Ask
  ask() : Int

effect Store
  save((Unit) -> Int) : Unit

fn leak() =
  with f <- handler
    ask() resume k => k(5)
    return r => r
  save(\(u) -> f.ask())

fn main() = leak()
