-- The marquee dimension error: zipping a length-3 and a length-4 vector. The
-- shared `n` forces equal lengths, so the mismatch is rejected naming both.
type Vec(a, n : Nat) = MkVec(List(a))

fn vzip(u : Vec(a, n), v : Vec(b, n)) : Vec((a, b), n) = MkVec([])

fn demo(v3 : Vec(Int, 3), v4 : Vec(Int, 4)) : Vec((Int, Int), 3) = vzip(v3, v4)
