-- Every cell of an N-element list built under `with_arena` comes from the
-- region's bump pointer, so the runtime allocation counter must not scale with
-- N. The whole structure is reclaimed wholesale at the handler's return; only
-- the scalar sum escapes.
import Arena (..)

fn build(n : Int, acc : List(Int)) : List(Int) =
  if n == 0 then
    acc
  else
    build(n - 1, Cons(n, acc))

fn total(xs : List(Int)) : Int =
  match xs of
    Nil => 0
    Cons(h, t) => h + total(t)

fn scratch() : Int = total(build(__N__, Nil))

fn main() = println(with_arena(scratch))
