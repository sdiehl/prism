-- Region activations in a loop: each turn builds a 64-cell list inside its own
-- `with_arena` activation and folds it to a scalar. Every list cell comes from
-- the region's bump pointer, so the 65 per-iteration constructor allocations
-- vanish from the runtime allocation counter; what remains per activation is
-- the two loop-invariant evidence closures of the handler itself (the ratchet
-- in perf_gate.rs pins that constant so the region path cannot silently
-- regress to per-cell malloc).
import Arena (..)

fn build(n : Int, acc : List(Int)) : List(Int) =
  if n == 0 then
    acc
  else
    build(n - 1, Cons(n, acc))

fn total(xs : List(Int)) : Int =
  match xs of
    Nil => 0
    Cons(h, t) => h + total(t)

fn scratch() : Int = total(build(64, Nil))

fn run(iters : Int) : Int =
  var acc := 0
  var i := 0
  while i < iters do
    i += 1
    acc += with_arena(scratch)
  acc

fn main() = println(run(__N__))
