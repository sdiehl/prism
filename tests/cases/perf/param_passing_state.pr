effect St
  rd() : Int
  wr(Int) : Unit

fn spin(k : Int) : Int ! {St} =
  if rd() < k then
    wr(rd() + 1)
    spin(k)
  else
    rd()

fn run(k : Int) : Int =
  let f =
    handle spin(k) with
      rd() resume r => \(s) -> r(s)(s)
      wr(v) resume r => \(_s) -> r(())(v)
      return x => \(_s) -> x
  f(0)

fn main() = println(run(__N__))
