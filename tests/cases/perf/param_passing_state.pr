effect St
  ctl rd(Unit) : Int
  ctl wr(Int) : Unit

fn spin(k : Int) : !{St} Int =
  if rd(()) < k then
    wr(rd(()) + 1)
    spin(k)
  else
    rd(())

fn run(k : Int) : Int =
  let f =
    handle spin(k) with
      rd(u, r) => \(s) -> r(s)(s)
      wr(v, r) => \(_s) -> r(())(v)
      return x => \(_s) -> x
  f(0)

fn main() = println(run(__N__))
