effect Abort
  ctl abort(Int) : Int

fn first(xs) =
  match xs of
    Nil => 0
    Cons(x, _) => x

fn walk(n : Int, acc) : !{Abort} Int =
  if n == 0 then
    abort(length(acc))
  else
    let cell = Cons(n, acc)
    let r = walk(n - 1, cell)
    r + first(cell)

fn deep_abort(n : Int) =
  handle walk(n, Nil) with
    final ctl abort(code) => code
    return r => r

fn main() = println(deep_abort(__N__))
