class Ord(a)
  cmp : (a, a) -> Int

instance ordInt : Ord(Int)
  fn cmp(x, y) =
    if x < y then
      0 - 1
    else
      1

instance ordRev : Ord(Int)
  fn cmp(x, y) =
    if x < y then
      1
    else
      0 - 1

canonical Ord(Int) = ordInt

canonical Ord(Int) = ordRev

fn main() = cmp(1, 2)
