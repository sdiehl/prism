-- Every source operation must be handled unless the adapter is explicitly
-- partial. An adapter that covers `get_v1` but omits `put_v1`, while the client
-- performs both, is rejected as an ordinary non-exhaustive handler for the
-- source effect.
effect KvV1
  get_v1(Int) : Int
  put_v1(Int, Int) : Unit

effect KvV2
  get_v2(Int) : Int
  put_v2(Int, Int) : Unit

fn adapt_partial(action) =
  handle action() with
    get_v1(key) resume k => k(get_v2(key))
    return r => r

fn client_v1() : Int ! {KvV1} =
  put_v1(1, 100)
  get_v1(1)
