-- Differential oracle for incremental computation: run a derivation
-- incrementally across a fixed sequence of edits, then run the same derivation
-- from scratch at the final input state, and assert the two agree. Because the
-- engine's result is content-addressed, "agree" is exact-value equality. This is
-- the refinement theorem in miniature: incremental evaluation equals from-scratch
-- evaluation.

import Data.Map (..)

import Data.List (..)

import Incr (..)

-- The derivation under test: a total and a descending ranking of names over a
-- score map. Written once, run both incrementally and from scratch.
fn edits() : List(List((String, Int))) =
  [[("a", 1), ("b", 2), ("c", 3)], [("a", 5), ("b", 2), ("c", 3)], [("a", 5), ("b", 2), ("c", 3)], [("a", 5), ("b", 9), ("c", 3)], [("a", 5), ("b", 9), ("c", 0)]]

fn ins_desc(p : (String, Int), xs : List((String, Int))) : List((String, Int)) =
  match xs of
    Nil => Cons(p, Nil)
    Cons(q, rest) =>
      if cmp(snd(p), snd(q)) > 0 then
        Cons(p, Cons(q, rest))
      else
        Cons(q, ins_desc(p, rest))

fn ranking_of(m : Map(String, Int)) : List(String) =
  map(fst, foldr(ins_desc, Nil, map_to_list(m)))

fn total_of(m : Map(String, Int)) : Int = sum(map_values(m))

-- Apply the edit sequence to one input, reading (total, ranking) after each edit
-- so the engine actually re-demands the affected cone; return the final observed
-- pair. The intermediate reads force recompute/cutoff, but the final observed
-- value must equal the from-scratch value.
fn drive(
  scores : Incr(Map(String, Int)),
  total : Incr(Int),
  ranking : Incr(List(String)),
  kvs_list : List(List((String, Int)))
) =
  match kvs_list of
    Nil => (get(total), get(ranking))
    Cons(kvs, rest) =>
      set(scores, map_from_list(kvs))
      let _r = (get(total), get(ranking))
      drive(scores, total, ranking, rest)

fn run_incremental() : (Int, List(String)) =
  run_incr() fn
    let first = head_or(edits(), Nil)
    let scores = input(map_from_list(first))
    let total = memo(\() -> total_of(get(scores)))
    let ranking = memo(\() -> ranking_of(get(scores)))
    drive(scores, total, ranking, edits())

fn head_or(xs : List(a), d : a) : a =
  match xs of
    Nil => d
    Cons(x, _) => x

fn run_scratch() : (Int, List(String)) =
  let last_edit = last_or(edits(), Nil)
  let m = map_from_list(last_edit)
  (total_of(m), ranking_of(m))

fn last_or(xs : List(a), d : a) : a =
  match xs of
    Nil => d
    Cons(x, Nil) => x
    Cons(_, rest) => last_or(rest, d)

fn eq_pair(p : (Int, List(String)), q : (Int, List(String))) : Bool =
  match p of
    (pt, pr) =>
      match q of
        (qt, qr) => pt == qt && list_eq_str(pr, qr)

fn list_eq_str(a : List(String), b : List(String)) : Bool =
  match a of
    Nil =>
      match b of
        Nil => true
        _ => false
    Cons(x, xs) =>
      match b of
        Nil => false
        Cons(y, ys) => str_eq(x, y) && list_eq_str(xs, ys)

pub fn main() =
  if eq_pair(run_incremental(), run_scratch()) then
    println("incremental == from-scratch: PASS")
  else
    println("incremental == from-scratch: FAIL")
