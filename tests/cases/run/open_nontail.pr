effect Ask
  ask() : Int

effect Log
  log(Int) : Unit

fn work() : Int ! {Ask, Log} =
  let a = ask()
  log(a)
  let b = ask()
  log(b)
  a + b

fn run() =
  handle (handle work() with {
      ask() resume k => let r = k(10) in let _ = println(r) in r + 100,
      return r => r * 2
    }) with
    log(n) resume k =>
      println(n)
      k(())
    return r => r

fn main() = println(run())
