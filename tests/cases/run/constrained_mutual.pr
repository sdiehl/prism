-- Mutually-recursive functions that both carry a `given Ord(k)` constraint must
-- thread the caller's dictionary to the sibling call, whether the group is pure
-- or effectful. The effectful case also forwards the effect through the sibling,
-- so both the dictionary evidence and the effect row survive to elaboration
-- (regression: an effect-carrying constrained SCC dropped one or the other).
effect St
  rd() : Int

fn ping(x : k, n : Int) : Int given Ord(k) =
  if n <= 0 then
    0
  else
    pong(x, n - 1)

fn pong(x : k, n : Int) : Int given Ord(k) =
  if cmp(x, x) == 0 then
    ping(x, n)
  else
    1

fn eff_a(x : k, n : Int) : Int ! {St} given Ord(k) =
  if n <= 0 then
    rd()
  else
    eff_b(x, n - 1)

fn eff_b(x : k, n : Int) : Int ! {St} given Ord(k) = eff_a(x, n)

fn main() =
  println(ping(5, 3))
  let r =
    handle eff_a(7, 2) with
      rd() resume k => k(9)
      return r => r
  println(r)
