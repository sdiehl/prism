-- `with handler` installs an effect handler over the rest of the block:
-- the statements below it become the handled expression, no extra indent.
effect Counter
  get() : Int
  bump() : Unit

fn counted() : Int =
  let run =
    with handler
      get() resume k => \(s) -> k(s)(s)
      bump() resume k => \(s) -> k(())(s + 1)
      return r => \(_s) -> r
    bump()
    bump()
    bump()
    get() * 2
  run(0)

fn main() =
  var total := counted()
  with handler
    get() resume k => k(7)
    bump() resume k => k(())
  bump()
  total := total + get()
  println(total)
