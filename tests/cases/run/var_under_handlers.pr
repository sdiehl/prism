-- Two user handlers with the var handler innermost: ops of both outer
-- effects are performed inside the var block and cross the var's handler.
effect Ask
  ask() : Int

effect Tick
  tick(Unit) : Unit

fn inner() : Int =
  var c := 0
  tick(())
  c := c + ask()
  tick(())
  c := c * 2
  c + ask()

fn middle() : Int =
  handle inner() with
    ask() resume k => k(5)
    return x => x

fn main() =
  let r =
    handle middle() with
      tick(u) resume k => k(()) + 100
      return x => x
  println(r)
