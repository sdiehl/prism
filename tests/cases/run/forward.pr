effect Log
  log(Int) : Unit

effect Exn
  raise(Int) : Int

fn work() : Int ! {Log, Exn} =
  log(1)
  log(2)
  let x = raise(0 - 7)
  log(x)
  x

fn run() =
  handle (handle work() with {
      log(n) resume k => let _ = println(n) in k(()),
      return r => r
    }) with
    raise(code) resume k => code
    return r => r

fn main() = println(run())
