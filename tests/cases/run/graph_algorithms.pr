import Data.Graph (..)

-- Two 3-cycles chained: {1,2,3} -> {4,5} -> and node 6 pointing into {4,5}.
fn g() =
  graph_from_edges([(1, 2), (2, 3), (3, 1), (3, 4), (4, 5), (5, 4), (6, 4)])

fn main() =
  println(show(graph_nodes(g())))
  println(show(graph_scc(g())))
  println(show(graph_topo_sort(g())))
  println(show(graph_dfs(g(), 1)))
  println(show(graph_bfs(g(), 1)))
  println(show(graph_successors(g(), 3)))
  println(show(graph_reachable(g(), 6)))
  println(show(graph_successors(graph_reverse(g()), 4)))
