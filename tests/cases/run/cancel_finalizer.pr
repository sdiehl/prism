-- A cancelled fiber runs its `on_cancel` (`never`) finalizer exactly
-- once. The worker parks at `yield`; the parent cancels it; on its next turn it
-- unwinds through the finalizer, which prints once, and never runs its tail.

import Concurrent (..)

fn guarded() : Int ! {Async(Int), IO} =
  println("worker: before yield")
  yield(())
  println("worker: after yield (must not print)")
  99

fn worker() : Int ! {Async(Int), IO} =
  on_cancel(\() -> println("finalizer ran"), guarded)

fn scene() : Int ! {Async(Int), IO} =
  let w = fork(worker)
  yield(())
  cancel(w)
  yield(())
  println("scene done")
  0

fn main() = println(run_async(scene))
