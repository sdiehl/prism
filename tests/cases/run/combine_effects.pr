effect Raise
  raise(Int) : Int

effect Tick
  tick(Unit) : Int

alias Boom = {Raise}

alias App = {Boom, Tick}

fn total(n) : Int ! {App} =
  let a = tick(())
  let b =
    if n == 0 then
      raise(a)
    else
      n * tick(())
  a + b

fn recover(n) : Int ! {Tick} =
  handle total(n) with
    raise(c) resume k => 0 - c
    return r => r

fn run_one(n) =
  let f =
    handle recover(n) with
      tick(u) resume k => \(s) -> k(s)(s + 1)
      return r => \(_s) -> r
  f(1)

fn main() =
  println(run_one(0))
  println(run_one(3))
  println(run_one(7))
