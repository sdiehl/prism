effect Counter
  get() : Int
  bump() : Unit

fn count_up() : Unit ! {Counter, IO} =
  while get() < 4 do
    println(get() * 10)
    bump()

fn main() =
  let f =
    handle count_up() with
      get() resume k => \(s) -> k(s)(s)
      bump() resume k => \(s) -> k(())(s + 1)
      return r => \(s) -> s
  println(f(0))
