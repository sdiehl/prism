-- A `once`-graded op handled tail-resumptively, and a `never`-graded op
-- handled by an aborting clause, both on user effects. Runs identically on the
-- interpreter and native backends.
effect Ask
  once ask() : Int

effect Abort
  never abort(Unit) : Int

fn asker() : Int ! {Ask} =
  let a = ask()
  let b = ask()
  a + b

fn aborter(n) : Int ! {Abort} =
  if n < 0 then
    abort(())
  else
    n * 2

fn main() : Unit ! {IO} =
  println(handle asker() with {
    once ask() => 21,
    return r => r
  })
  println(handle aborter(5) with {
    never abort(u) => 0,
    return r => r
  })
  println(handle aborter(0 - 1) with {
    never abort(u) => 999,
    return r => r
  })
