-- Qualifiers fold inside-out: binds enter scope for later qualifiers and the
-- head, guards drop elements, and the statement form shares the same path.

fn main() =
  let xs = [y for x in srange(1, 8), if even(x), let y = x * x, if y > 10]
  for v in sof(xs) do
    println(v)
  for x in srange(1, 5),
      let d = x * x,
      if odd(d) do
    println(d)
  println(ssum(sof([x for x in srange(1, 5)])))
  -- Failable guard: `at_list` fails past the end, so the guard prunes those
  -- indices (and the `false` flag) instead of escaping. Keeps 0 and 2.
  let flags = [true, false, true]
  for i in srange(0, 6),
      if at_list(flags, i) do
    println(i)
