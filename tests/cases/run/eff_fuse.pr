-- A fused emit pipeline: an open tail-resumptive handler whose
-- `once give` clause re-performs `give` to the outer consumer. Evidence passing
-- inlines every stage into direct forced-clause calls, so the producer ->
-- transformer -> consumer chain runs as one loop with zero EOp cells, the
-- fusion that intermediate-collection pipelines pay for. Output 10 20 30.
effect Yield
  give(Int) : Unit

fn produce() : Unit ! {Yield} =
  give(1)
  give(2)
  give(3)

fn mapped() : Unit ! {Yield} =
  handle produce() with
    once give(x) => give(x * 10)
    return r => r

fn main() =
  handle mapped() with
    once give(x) => println(x)
    return r => r
