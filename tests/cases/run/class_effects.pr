effect Out
  out(Int) : Unit

class Rank(a)
  rank : (a) -> Int

instance rankInt : Rank(Int)
  fn rank(x) = x * 10

instance rankBool : Rank(Bool)
  fn rank(b) =
    if b then
      1
    else
      0

fn out_rank(x : a) : Unit ! {Out} given Rank(a) = out(rank(x))

fn work() : Int ! {Out} =
  out_rank(4)
  out_rank(true)
  rank(7)

fn main() =
  println(handle work() with {
    out(n) resume k => let _ = println(n) in k(()),
    return r => r
  })
