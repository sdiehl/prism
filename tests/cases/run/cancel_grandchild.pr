-- Cancellation reaches a grandchild. The child forks a grandchild; both
-- loop at `yield`, so cancelling the child unwinds both, running both
-- finalizers. Looping bodies keep both fibers parked so the cancel is
-- deterministic regardless of interleaving.

import Concurrent (..)

fn gkid_loop() : Int ! {Async(Int), IO} =
  yield()
  gkid_loop()

fn gkid_body() : Int ! {Async(Int), IO} =
  println("grandchild: running")
  gkid_loop()

fn gkid() : Int ! {Async(Int), IO} =
  on_cancel(\() -> println("grandchild finalizer ran"), gkid_body)

fn child_loop() : Int ! {Async(Int), IO} =
  yield()
  child_loop()

fn child_body() : Int ! {Async(Int), IO} =
  let g = fork(gkid)
  println("child: running")
  child_loop()

fn child() : Int ! {Async(Int), IO} =
  on_cancel(\() -> println("child finalizer ran"), child_body)

fn scene() : Int ! {Async(Int), IO} =
  let c = fork(child)
  yield()
  yield()
  yield()
  cancel(c)
  yield()
  yield()
  yield()
  println("scene done")
  0

fn main_child_cleanup() : Unit ! {Async(Int), IO} =
  println("main descendant cleanup ran")

fn main_child_body(c : Chan) : Int ! {Async(Int), IO} =
  println("main descendant: parked")
  send(c, 1)
  recv(c)

fn main_child(c : Chan) : Int ! {Async(Int), IO} =
  on_cancel(main_child_cleanup, \() -> main_child_body(c))

fn cancel_main_scene() : Int ! {Async(Int), IO} =
  let c = channel()
  let _child = fork(\() -> main_child(c))
  recv(c)
  cancel(Fiber(0))
  yield()
  99

fn main() =
  println(run_async(scene))
  let cancelled_main = default(\() -> run_lifo(cancel_main_scene), 0 - 7)
  println("main cancellation recovered with {cancelled_main}")
