effect Cfg
  ask() : Int
  config() : Int
  tell(Int) : Unit

fn use_env() : Int ! {Cfg} =
  tell(ask())
  tell(config())
  tell(config())
  config() + ask()

-- One handler mixing all three clause forms. The val RHS prints 999 exactly
-- once at install time even though config() is used three times, so {IO} is
-- attributed here, not to use_env's {Cfg} row.
fn run_env(env : Int) : Int ! {IO} =
  handle use_env() with
    once ask() => env * 2
    val config =
      println(999)
      41
    tell(x) resume k =>
      println(x)
      k(())
    return r => r

fn add_two() : Int ! {Cfg} = ask() + ask()

-- Handlers cover every `Cfg` op (coverage is checked); only `ask` ever fires
-- in `add_two`/`mid`, the other arms exist to make the discharge honest.
fn mid() : Int ! {Cfg} =
  let inner =
    handle add_two() with
      once ask() => 7
      config() resume k => k(0)
      tell(x) resume k => k(())
      return r => r
  inner + ask()

-- Nested handlers: the inner `once` clause shadows the outer one for add_two.
fn nested() : Int =
  handle mid() with
    once ask() => 100
    config() resume k => k(0)
    tell(x) resume k => k(())
    return r => r

fn main() =
  println(run_env(5))
  println(nested())
