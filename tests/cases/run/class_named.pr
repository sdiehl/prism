instance ordRev : Ord(Int) {
  fn cmp(x, y) = int_cmp(y, x)
}

fn print_all(xs) =
  match xs of
    Nil => ()
    Cons(x, rest) =>
      println(x)
      print_all(rest)

fn main() =
  println(cmp[ordInt](1, 2))
  println(cmp[ordRev](1, 2))
  print_all(sort_by_ord[ordInt]([3, 1, 2]))
  print_all(sort_by_ord[ordRev]([3, 1, 2]))
