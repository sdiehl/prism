instance ordRev : Ord(Int)
  fn cmp(x, y) = int_cmp(y, x)

canonical Ord(Int) = ordInt

fn print_all(xs : List(Int)) =
  match xs of
    Nil => ()
    Cons(x, rest) =>
      println(x)
      print_all(rest)

fn main() =
  println(cmp(1, 2, using ordInt))
  println(cmp(1, 2, using ordRev))
  print_all(sort_by_ord([3, 1, 2], using ordInt))
  print_all(sort_by_ord([3, 1, 2], using ordRev))
