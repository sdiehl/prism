-- Holes render through show: records, lists, and effect ops under a handler.
type Point = Point { x: Int, y: Int }

effect Ask
  ask() : Int

fn main() =
  let p = Point { x = 1, y = 2 }
  let xs = [1, 2, 3]
  println("p = {p}")
  println("xs = {xs}")
  with handler
    ask() resume k => k(21)
  println("answer = {ask() * 2}")
