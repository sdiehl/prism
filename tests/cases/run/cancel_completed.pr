-- Cancelling an already-completed fiber is a no-op.

import Concurrent (..)

fn quick() : Int ! {Async(Int), IO} =
  println("quick: done")
  7

fn scene() : Int ! {Async(Int), IO} =
  let q = fork(quick)
  let v = await(q)
  println("awaited {v}")
  cancel(q)
  println("cancel of completed fiber was a no-op")
  v

fn main() = println(run_async(scene))
