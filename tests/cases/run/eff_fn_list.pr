-- Effectful functions stored in a list, then extracted and piped through
-- under a handler.

effect Out
  out(Int) : Unit

fn shout(x) =
  out(x)
  x + 1

fn double(x) =
  out(0 - x)
  x * 2

fn pipe(fs, x) =
  match fs of
    Nil => x
    Cons(f, rest) => pipe(rest, f(x))

fn main() =
  println(handle pipe(Cons(shout, Cons(double, Cons(shout, Nil))), 5) with {
    out(v) resume k => let _ = println(v) in k(()),
    return r => r
  })
