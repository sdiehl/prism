-- Dot chains over the string builtins, which are all receiver-first:
-- substring, concat, str_len, char_at, parse_int, show_int.

fn main() =
  let s = "prism"
  println(s.substring(1, 3).str_len())
  println(s.concat(" rocks").str_len())
  println(unwrap_or(0, "40".concat("2").parse_int()))
  println(s.substring(0, 1).concat("!").concat(s.substring(4, 1)))
  println(s.char_at(0).show_int().concat(" code").str_len())
