fn len(borrow xs) =
  match xs of
    Nil => 0
    Cons(x, rest) => 1 + len(rest)

fn scale(borrow xs, k) =
  match xs of
    Nil => Nil
    Cons(x, rest) => Cons(x * k, scale(rest, k))

fn main() =
  let xs = [1, 2, 3, 4]
  let n = len(xs)
  let ys = scale(xs, n)
  println(n)
  println(sum(ys))
  println(sum(xs))
