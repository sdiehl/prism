  println(show_float(atan2(3.0, 4.0)))
  println(show_float(atan2(0.0, 1.0)))
  println(show_float(atan2(7.5, 2.0)))
  println(show_float(atan2(-7.5, 2.0)))
  println(show_float(atan2(2.0, 10.0)))

