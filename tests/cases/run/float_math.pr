-- Owned-numerics conformance: every FloatOp/binary builtin over hard-case
-- inputs (near multiples of pi/2, negatives, extremes, signed zero, saturating
-- conversions). The parity gate runs this on both backends and diffs the
-- output; `show_float` round-trips, so equal lines mean bit-identical results.
-- Chunked into parts because the tree-walking interpreter's `let` nesting is
-- bounded, and explicit (a pure builtin will not unify against an effectful
-- higher-order parameter).

fn part0() =
  println(show_float(sin(0.0)))
  println(show_float(sin(0.5)))
  println(show_float(sin(1.0)))
  println(show_float(sin(-1.0)))
  println(show_float(sin(1.5707963267948966)))
  println(show_float(sin(3.141592653589793)))
  println(show_float(sin(-0.0)))
  println(show_float(sin(100.0)))
  println(show_float(sin(0.0001)))
  println(show_float(sin(12345.6789)))
  println(show_float(cos(0.0)))
  println(show_float(cos(0.5)))
  println(show_float(cos(1.0)))
  println(show_float(cos(-1.0)))
  println(show_float(cos(1.5707963267948966)))
  println(show_float(cos(3.141592653589793)))
  println(show_float(cos(-0.0)))
  println(show_float(cos(100.0)))
  println(show_float(cos(0.0001)))
  println(show_float(cos(12345.6789)))
  println(show_float(tan(0.0)))
  println(show_float(tan(0.5)))
  println(show_float(tan(1.0)))
  println(show_float(tan(-1.0)))
  println(show_float(tan(1.5707963267948966)))
  println(show_float(tan(3.141592653589793)))
  println(show_float(tan(-0.0)))
  println(show_float(tan(100.0)))
  println(show_float(tan(0.0001)))
  println(show_float(tan(12345.6789)))

