fn part5() =
  println(show_float(asin(0.5)))
  println(show_float(asin(-0.5)))
  println(show_float(asin(0.0)))
  println(show_float(asin(1.0)))
  println(show_float(asin(-1.0)))
  println(show_float(acos(0.5)))
  println(show_float(acos(-0.5)))
  println(show_float(acos(0.0)))
  println(show_float(acos(1.0)))
  println(show_float(sqrt(0.0)))
  println(show_float(sqrt(2.0)))
  println(show_float(sqrt(1.0)))
  println(show_float(sqrt(1e300)))
  println(show_float(sqrt(0.0001)))
  println(show_float(cbrt(0.0)))
  println(show_float(cbrt(27.0)))
  println(show_float(cbrt(-8.0)))
  println(show_float(cbrt(2.0)))
  println(show_float(cbrt(-0.0)))
  println(show_float(ln(1.0)))
  println(show_float(ln(2.718281828459045)))
  println(show_float(ln(10.0)))
  println(show_float(ln(0.5)))
  println(show_float(ln(100.0)))
  println(show_float(log2(1.0)))
