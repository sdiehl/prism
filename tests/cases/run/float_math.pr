  println(show_float(log2(0.5)))
  println(show_float(log2(3.0)))
  println(show_float(log10(1.0)))
  println(show_float(log10(1000.0)))

fn part6() =
  println(show_float(log10(0.5)))
  println(show_float(log10(100.0)))
  println(show_float(log1p(0.0)))
  println(show_float(log1p(0.0001)))
  println(show_float(log1p(1.0)))
  println(show_float(log1p(-0.5)))
  println(show_int(floor_to_int(3.999)))
  println(show_int(floor_to_int(-3.001)))
  println(show_int(ceil_to_int(3.001)))
  println(show_int(ceil_to_int(-3.999)))
  println(show_int(truncate(-3.9)))
  println(show_int(truncate(3.9)))
  println(show_int(truncate(1e300)))
  println(show_int(truncate(-1e300)))
  println(show_float(to_float(42)))
