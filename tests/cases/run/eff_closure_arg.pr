-- An effectful closure passed as a function argument and applied under a
-- handler. The do sits in a lambda body, invisible to latent analysis.

effect Tell {
  ctl tell(Int) : Int
}

fn apply_twice(f, x) = f(f(x))

fn main() =
  println(handle apply_twice(\(n) -> tell(n) + n, 3) with {
    tell(v, k) => k(v * 10),
    return r => r
  })
