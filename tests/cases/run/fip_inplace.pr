-- FP^2 in-place discipline pinned end to end: a reverse-onto-accumulator whose
-- rebuilt Cons is not in tail position (it feeds the recursive call), a
-- spine-rebuilding bump, and a tree relabel that reuses every node. All carry
-- the `fbip` annotation, so the compiler proves they allocate nothing fresh; the
-- reuse credit refinement is what lets the non-tail Cons reuse the freed cell.

fbip fn rev_onto(xs, acc) =
  match xs of
    Nil => acc
    Cons(h, t) => rev_onto(t, Cons(h, acc))

fbip fn bump(xs) =
  match xs of
    Nil => Nil
    Cons(h, t) => Cons(h + 1, bump(t))

type Tree = Leaf | Node(Tree, Int, Tree)

fbip fn relabel(t) =
  match t of
    Leaf => Leaf
    Node(l, x, r) => Node(relabel(l), x + x, relabel(r))

fn sum_tree(t) =
  match t of
    Leaf => 0
    Node(l, x, r) => sum_tree(l) + x + sum_tree(r)

fn main() =
  println(sum(rev_onto([1, 2, 3, 4], Nil)))
  println(sum(bump([10, 20, 30])))
  println(sum_tree(relabel(Node(Node(Leaf, 1, Leaf), 2, Node(Leaf, 3, Leaf)))))
