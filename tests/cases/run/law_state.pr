-- Property-tests the three algebraic laws of the parameter-passing State
-- handler, the flagship of the quickcheck harness: the laws hold for every
-- generated state, not one hand-picked value, and the run is deterministic in
-- the seed. Each law compares two programs that must be observationally equal
-- (same result AND same final state) under `run_state`.

import Quickcheck (..)

effect State
  get() : Int
  put(Int) : Unit

-- The canonical State handler: parameter-passing, returning (result, final).
fn run_state(s0, action : () -> a ! {State | e}) =
  let f =
    handle action() with
      get() resume k => \(s) -> k(s)(s)
      put(v) resume k => \(_s) -> k(())(v)
      return r => \(s) -> (r, s)
  f(s0)

fn state_eq(l, r) = fst(l) == fst(r) && snd(l) == snd(r)

-- get-get: a second `get` with no intervening `put` observes the same value.
fn gg_lhs() =
  let a = get()
  let b = get()
  a + b * 7

fn gg_rhs() =
  let a = get()
  a + a * 7

fn prop_get_get(s0) = state_eq(run_state(s0, gg_lhs), run_state(s0, gg_rhs))

-- put-get: after `put(s)`, `get` returns `s` (equivalently, returning `s`).
fn pg_lhs(s) =
  put(s)
  get()

fn pg_rhs(s) =
  put(s)
  s

fn prop_put_get(p) =
  match p of
    (s0, s) =>
      state_eq(run_state(s0, \() -> pg_lhs(s)), run_state(s0, \() -> pg_rhs(s)))

-- put-put: an overwritten `put` is dead; only the last write survives.
fn pp_lhs(s1, s2) =
  put(s1)
  put(s2)
  get()

fn pp_rhs(s2) =
  put(s2)
  get()

fn prop_put_put(t) =
  match t of
    (s0, s1, s2) =>
      state_eq(
          run_state(s0, \() -> pp_lhs(s1, s2)),
          run_state(s0, \() -> pp_rhs(s2)),
        )

fn main() =
  println(show_outcome("State get-get", quickcheck(gen_int, prop_get_get)))
  println(
      show_outcome(
          "State put-get",
          quickcheck(gen_pair(gen_int, gen_int), prop_put_get),
        ),
    )
  println(
      show_outcome(
          "State put-put",
          quickcheck(gen_triple(gen_int, gen_int, gen_int), prop_put_put),
        ),
    )
