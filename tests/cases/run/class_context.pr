instance ordList : Ord(List(a)) given Ord(a)
  fn cmp(xs, ys) =
    match xs of
      Nil =>
        match ys of
          Nil => 0
          Cons(_, _) => 0 - 1
      Cons(x, xt) =>
        match ys of
          Nil => 1
          Cons(y, yt) =>
            let c = cmp(x, y)
            if c == 0 then
              cmp(xt, yt)
            else
              c

fn print_all(xs : List(Int)) =
  match xs of
    Nil => ()
    Cons(x, rest) =>
      println(x)
      print_all(rest)

fn encode(xs) = foldl(\(a, x) -> a * 10 + x, 0, xs)

fn main() =
  println(cmp([1, 2], [1, 3]))
  println(cmp([1, 2, 3], [1, 2]))
  println(cmp([[1, 2], [3, 4]], [[1, 2], [3, 4]]))
  print_all(map(encode, sort_by_ord([[3, 1], [2, 9], [3, 1, 4]])))
