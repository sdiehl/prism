== types ==
apply_io : ((Int) -> Int ! {IO}) -> Int ! {IO}
use_pure : (forall e0. (Int) -> Int ! {e0}) -> Int ! {IO}
call_poly : forall e1. (forall e0. ((Int) -> Int ! {e1}) -> Int ! {e0}, (Int) -> Int ! {e1}) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn apply_io(g) =
  return 1 to t@0; return g to t@1; (force t@1)(t@0)
fn use_pure(h) =
  return h to t@2; apply_io(t@2)
fn call_poly(h, f) =
  return f to t@3; return h to t@4; (force t@4)(t@3)
fn main() =
  return thunk { \x. return x to t@5; return 41 to t@6; t@5 + t@6 } to t@7; use_pure(t@7) to t@8; print t@8 to t@9; print_nl to _; return thunk { \g. return 1 to t@10; return g to t@11; (force t@11)(t@10) } to t@12; return thunk { \x. return x to t@13; return 41 to t@14; t@13 + t@14 } to t@15; call_poly(t@12, t@15) to t@16; print t@16 to t@17; print_nl

== fbip (rc) ==
fn apply_io(g) =
  return 1 to t@0; return g to t@1; (force t@1)(t@0)
fn use_pure(h) =
  return h to t@2; apply_io(t@2)
fn call_poly(h, f) =
  return f to t@3; return h to t@4; (force t@4)(t@3)
fn main() =
  return thunk { \x. return x to t@5; return 41 to t@6; t@5 + t@6 } to t@7; use_pure(t@7) to t@8; print t@8 to t@9; drop t@9 to _; print_nl to _; drop _ to _; return thunk { \g. return 1 to t@10; return g to t@11; (force t@11)(t@10) } to t@12; return thunk { \x. return x to t@13; return 41 to t@14; t@13 + t@14 } to t@15; call_poly(t@12, t@15) to t@16; print t@16 to t@17; drop t@17 to _; print_nl

