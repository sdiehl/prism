== core (cbpv) ==
fn apply_io(g) =
  return 1 to t@0
  return g to t@1
  (force t@1)(t@0)
fn use_pure(h) =
  return h to t@2
  apply_io(t@2)
fn call_poly(h, f) =
  return f to t@3
  return h to t@4
  (force t@4)(t@3)
fn main() =
  thunk { \x.
    return x to t@5
    return 41 to t@6
    t@5 + t@6
  } to t@7
  use_pure(t@7) to t@8
  print t@8 to t@9
  print_nl

== fbip (rc) ==
fn apply_io(g) =
  return 1 to t@0
  return g to t@1
  (force t@1)(t@0)
fn use_pure(h) =
  return h to t@2
  apply_io(t@2)
fn call_poly(h, f) =
  return f to t@3
  return h to t@4
  (force t@4)(t@3)
fn main() =
  thunk { \x.
    return x to t@5
    return 41 to t@6
    t@5 + t@6
  } to t@7
  use_pure(t@7) to t@8
  print t@8 to t@9
  drop t@9
  print_nl

