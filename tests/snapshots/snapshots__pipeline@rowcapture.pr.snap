; ModuleID = 'prism'
source_filename = "prism"

define i64 @prism_apply_io(i64 %a0) {
entry:
  %t0 = call i64 @prism_apply_1(i64 %a0, i64 3)
  call void @prism_rc_dec(i64 %a0)
  ret i64 %t0
}

define i64 @prism_apply_1(i64 %_clos, i64 %_a0) {
entry:
  %_cp = inttoptr i64 %_clos to ptr
  %0 = ptrtoint ptr %_cp to i64
  %1 = add i64 %0, 8
  %_tp = inttoptr i64 %1 to ptr
  %_tag = load i64, ptr %_tp, align 8
  switch i64 %_tag, label %_dead [
    i64 0, label %_lam0
    i64 1, label %_lam1
    i64 2, label %_lam2
  ]

_lam0:                                            ; preds = %entry
  %_r0 = call i64 @prism_lam_0(i64 %_a0)
  br label %_merge

_lam1:                                            ; preds = %entry
  %_r1 = call i64 @prism_lam_1(i64 %_a0)
  br label %_merge

_lam2:                                            ; preds = %entry
  %_r2 = call i64 @prism_lam_2(i64 %_a0)
  br label %_merge

_dead:                                            ; preds = %entry
  call void @prism_apply_error()
  unreachable

_merge:                                           ; preds = %_lam2, %_lam1, %_lam0
  %_result = phi i64 [ %_r0, %_lam0 ], [ %_r1, %_lam1 ], [ %_r2, %_lam2 ]
  ret i64 %_result
}

declare void @prism_rc_dec(i64)

define i64 @prism_use_pure(i64 %a0) {
entry:
  %t0 = musttail call i64 @prism_apply_io(i64 %a0)
  ret i64 %t0
}

define i64 @prism_call_poly(i64 %a0, i64 %a1) {
entry:
  %t0 = call i64 @prism_apply_1(i64 %a0, i64 %a1)
  call void @prism_rc_dec(i64 %a0)
  ret i64 %t0
}

define i64 @prism_main() {
entry:
  %t0 = call ptr @prism_alloc(i64 0)
  %0 = ptrtoint ptr %t0 to i64
  %1 = add i64 %0, 8
  %t1 = inttoptr i64 %1 to ptr
  store i64 0, ptr %t1, align 8
  %t2 = ptrtoint ptr %t0 to i64
  %t3 = call i64 @prism_use_pure(i64 %t2)
  call void @prism_print_int(i64 %t3)
  call void @prism_rc_dec(i64 %t3)
  call void @prism_rc_dec(i64 0)
  call void @prism_print_nl()
  call void @prism_rc_dec(i64 0)
  %t6 = call ptr @prism_alloc(i64 0)
  %2 = ptrtoint ptr %t6 to i64
  %3 = add i64 %2, 8
  %t7 = inttoptr i64 %3 to ptr
  store i64 1, ptr %t7, align 8
  %t8 = ptrtoint ptr %t6 to i64
  %t9 = call ptr @prism_alloc(i64 0)
  %4 = ptrtoint ptr %t9 to i64
  %5 = add i64 %4, 8
  %t10 = inttoptr i64 %5 to ptr
  store i64 2, ptr %t10, align 8
  %t11 = ptrtoint ptr %t9 to i64
  %t12 = call i64 @prism_call_poly(i64 %t8, i64 %t11)
  call void @prism_print_int(i64 %t12)
  call void @prism_rc_dec(i64 %t12)
  call void @prism_rc_dec(i64 0)
  call void @prism_print_nl()
  ret i64 0
}

declare ptr @prism_alloc(i64)

declare void @prism_print_int(i64)

declare void @prism_print_nl()

define i64 @prism_lam_0(i64 %_p0) {
entry:
  %t0 = and i64 %_p0, 83
  %t1 = and i64 %t0, 1
  %t2 = icmp eq i64 %t1, 1
  br i1 %t2, label %b0, label %b1

