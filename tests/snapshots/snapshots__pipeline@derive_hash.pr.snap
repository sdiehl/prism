fn main() =
  return 1 to t@0
  return 2 to t@1
  return MkPair(t@0, t@1) to t@2
  i@hashPair@hash(t@2)
fn i@hashInt@hash(x) =
  return "i" to t@3
  return x to t@4
  show_int(t@4) to t@5
  concat(t@3, t@5) to t@6
  blake3(t@6)
fn hashInt() =
  return _DHash(thunk { \_p0. i@hashInt@hash(_p0) })
fn i@hashPair@hash(_x) =
  return _x to t@7
  case t@7 of
    MkPair(_f0, _f1) =>
      dup _f0
      dup _f1
      drop t@7
      return "c6:MkPair/0" to t@8
      return _f0 to t@9
      i@hashInt@hash(t@9) to t@10
      return _f1 to t@11
      i@hashInt@hash(t@11) to t@12
      concat(t@10, t@12) to t@13
      concat(t@8, t@13) to t@14
      blake3(t@14)
fn hashPair() =
  return _DHash(thunk { \_p0. i@hashPair@hash(_p0) })

