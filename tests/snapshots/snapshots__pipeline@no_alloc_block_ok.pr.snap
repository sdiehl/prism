== types ==
tick : (Int) -> Int
main : () -> Int
noalloc@0 : (Int) -> Int

== core (cbpv) ==
fn tick(n) =
  return n to t@0; return 1 to t@1; t@0 + t@1 to base; return base to t@2; noalloc@0(t@2)
fn main() =
  return 20 to t@3; tick(t@3)
fn noalloc@0(base) =
  return base to t@4; return base to t@5; t@4 + t@5

== fbip (rc) ==
fn tick(n) =
  return n to t@0; return 1 to t@1; t@0 + t@1 to base; return base to t@2; noalloc@0(t@2)
fn main() =
  return 20 to t@3; tick(t@3)
fn noalloc@0(base) =
  dup base to _; return base to t@4; return base to t@5; t@4 + t@5

