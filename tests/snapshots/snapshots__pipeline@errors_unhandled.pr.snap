== core (cbpv) ==
fn lookup(k) =
  return k to t@0; return "x" to t@1; str_eq(t@0, t@1) to t@3; if t@3 then (return 1) else (return k to t@2; do throw@NotFound(t@2))
fn main() =
  return "y" to t@4; lookup(t@4) to t@5; print t@5 to t@6; print_nl

== fbip (rc) ==
fn lookup(k) =
  dup k to _; return k to t@0; return "x" to t@1; str_eq(t@0, t@1) to t@3; if t@3 then (drop t@3 to _; drop k to _; return 1) else (drop t@3 to _; return k to t@2; do throw@NotFound(t@2))
fn main() =
  return "y" to t@4; lookup(t@4) to t@5; print t@5 to t@6; drop t@6 to _; print_nl

