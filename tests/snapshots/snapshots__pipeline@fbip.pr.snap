== types ==
main : () -> Int

== core (cbpv) ==
fn main() =
  return 1 to t@0; return 2 to t@1; return Pair(t@0, t@1) to shared; return 7 to t@2; return 8 to t@3; return Pair(t@2, t@3) to dead; return shared to t@4; case t@4 { Pair(a, b) => return shared to t@5; case t@5 { Pair(c, d) => return a to t@6; return b to t@7; t@6 + t@7 to t@8; return c to t@9; t@8 + t@9 to t@10; return d to t@11; t@10 + t@11 } }

== fbip (rc) ==
fn main() =
  return 1 to t@0; return 2 to t@1; return Pair(t@0, t@1) to shared; return 7 to t@2; return 8 to t@3; return Pair(t@2, t@3) to dead; drop dead to _; dup shared to _; return shared to t@4; case t@4 { Pair(a, b) => dup a to _; dup b to _; drop t@4 to _; return shared to t@5; case t@5 { Pair(c, d) => dup c to _; dup d to _; drop t@5 to _; return a to t@6; return b to t@7; t@6 + t@7 to t@8; return c to t@9; t@8 + t@9 to t@10; return d to t@11; t@10 + t@11 } }

