== types ==
inc : (Int) -> Int
twice : (Int) -> Int
main : () -> Int

== core (cbpv) ==
fn inc(x) =
  return x to t@0; return 1 to t@1; t@0 + t@1
fn twice(x) =
  return x to t@2; inc(t@2) to t@3; inc(t@3)
fn main() =
  return 40 to t@4; twice(t@4)

== fbip (rc) ==
fn inc(x) =
  return x to t@0; return 1 to t@1; t@0 + t@1
fn twice(x) =
  return x to t@2; inc(t@2) to t@3; inc(t@3)
fn main() =
  return 40 to t@4; twice(t@4)

