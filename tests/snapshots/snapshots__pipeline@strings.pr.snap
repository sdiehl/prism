== types ==
greet : (String) -> String
describe : (Int) -> String
main : () -> Unit ! {IO}

== core (cbpv) ==
fn greet(name) =
  return "hello " to t@0; return name to t@1; concat(t@0, t@1)
fn describe(n) =
  return n to t@2; show_int(t@2) to t@3; return n to t@4; return 1 to t@5; t@4 == t@5 to t@6; if t@6 then (return " item") else (return " items") to t@7; concat(t@3, t@7)
fn main() =
  return "world" to t@8; greet(t@8) to t@9; prints t@9 to t@10; print_nl to _; return 1 to t@11; describe(t@11) to t@12; prints t@12 to t@13; print_nl to _; return 3 to t@14; describe(t@14) to t@15; prints t@15 to t@16; print_nl to _; return "a" to t@17; return "a" to t@18; str_eq(t@17, t@18) to t@19; show_bool(t@19) to t@20; prints t@20 to t@21; print_nl to _; return "prism" to t@22; str_len(t@22) to t@23; show_int(t@23) to t@24; prints t@24 to t@25; print_nl

== fbip (rc) ==
fn greet(name) =
  return "hello " to t@0; return name to t@1; concat(t@0, t@1)
fn describe(n) =
  dup n to _; return n to t@2; show_int(t@2) to t@3; return n to t@4; return 1 to t@5; t@4 == t@5 to t@6; if t@6 then (drop t@6 to _; return " item") else (drop t@6 to _; return " items") to t@7; concat(t@3, t@7)
fn main() =
  return "world" to t@8; greet(t@8) to t@9; prints t@9 to t@10; drop t@10 to _; print_nl to _; drop _ to _; return 1 to t@11; describe(t@11) to t@12; prints t@12 to t@13; drop t@13 to _; print_nl to _; drop _ to _; return 3 to t@14; describe(t@14) to t@15; prints t@15 to t@16; drop t@16 to _; print_nl to _; drop _ to _; return "a" to t@17; return "a" to t@18; str_eq(t@17, t@18) to t@19; show_bool(t@19) to t@20; prints t@20 to t@21; drop t@21 to _; print_nl to _; drop _ to _; return "prism" to t@22; str_len(t@22) to t@23; show_int(t@23) to t@24; prints t@24 to t@25; drop t@25 to _; print_nl

