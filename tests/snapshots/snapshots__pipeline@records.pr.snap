== types ==
make : (Int, Int) -> Point
sum_coords : (Point) -> Int
shift_x : (Point, Int) -> Point
main : () -> Unit ! {IO}

== core (cbpv) ==
fn make(a, b) =
  return a to t@0; return b to t@1; return Point(t@0, t@1)
fn sum_coords(p) =
  return p to t@2; case t@2 { Point(px, py) => return px to t@3; return py to t@4; t@3 + t@4 }
fn shift_x(p, dx) =
  return p to t@5; case t@5 { Point(t@6, _) => return t@6 } to t@6; case t@5 { Point(_, t@7) => return t@7 } to t@7; return dx to t@8; return Point(t@8, t@7)
fn main() =
  return 3 to t@9; return 4 to t@10; make(t@9, t@10) to p; return p to t@11; sum_coords(t@11) to s; return p to t@12; return 10 to t@13; shift_x(t@12, t@13) to q; return q to t@14; sum_coords(t@14) to t; return s to t@15; print t@15 to t@16; print_nl

== fbip (rc) ==
fn make(a, b) =
  return a to t@0; return b to t@1; return Point(t@0, t@1)
fn sum_coords(p) =
  return p to t@2; case t@2 { Point(px, py) => dup px to _; dup py to _; drop t@2 to _; return px to t@3; return py to t@4; t@3 + t@4 }
fn shift_x(p, dx) =
  return p to t@5; dup t@5 to _; case t@5 { Point(t@6, _) => dup t@6 to _; drop t@5 to _; return t@6 } to t@6; drop t@6 to _; case t@5 { Point(_, t@7) => dup t@7 to _; drop t@5 to _; return t@7 } to t@7; return dx to t@8; return Point(t@8, t@7)
fn main() =
  return 3 to t@9; return 4 to t@10; make(t@9, t@10) to p; dup p to _; return p to t@11; sum_coords(t@11) to s; return p to t@12; return 10 to t@13; shift_x(t@12, t@13) to q; return q to t@14; sum_coords(t@14) to t; drop t to _; return s to t@15; print t@15 to t@16; drop t@16 to _; print_nl

