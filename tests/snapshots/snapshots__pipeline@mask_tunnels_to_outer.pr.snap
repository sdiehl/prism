== types ==
f : () -> Int ! {E}
main : () -> Unit ! {IO}

== core (cbpv) ==
fn f() =
  handle { mask<op> { return 1 to t@0; do op(t@0) } } with { op(x, k) => return x to t@1; return k to t@2; (force t@2)(t@1), return r => return r }
fn main() =
  handle { f() } with { op(x, k) => return x to t@3; return 100 to t@4; t@3 + t@4 to t@5; return k to t@6; (force t@6)(t@5), return r => return r } to r; return r to t@7; print t@7 to t@8; print_nl

== fbip (rc) ==
fn f() =
  handle { mask<op> { return 1 to t@0; do op(t@0) } } with { op(x, k) => return x to t@1; return k to t@2; (force t@2)(t@1), return r => return r }
fn main() =
  handle { f() } with { op(x, k) => return x to t@3; return 100 to t@4; t@3 + t@4 to t@5; return k to t@6; (force t@6)(t@5), return r => return r } to r; return r to t@7; print t@7 to t@8; drop t@8 to _; print_nl

