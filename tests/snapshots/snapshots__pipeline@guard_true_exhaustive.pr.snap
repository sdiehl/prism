== core (cbpv) ==
fn classify(n) =
  return n to t@0; t@0 == 0 to t@3; if t@3 then (return 0) else (return t@0 to t@1; return t@1 to x; return true to t@2; if t@2 then (return t@1 to x; return 1) else (case t@0 { _ => error "ICE: guarded match fell through" }))
fn main() =
  return 5 to t@4; classify(t@4)

== fbip (rc) ==
fn classify(n) =
  return n to t@0; dup t@0 to _; t@0 == 0 to t@3; if t@3 then (drop t@3 to _; drop t@0 to _; return 0) else (drop t@3 to _; dup t@0 to _; return t@0 to t@1; dup t@1 to _; return t@1 to x; drop x to _; return true to t@2; if t@2 then (drop t@2 to _; drop t@0 to _; return t@1 to x; drop x to _; return 1) else (case t@0 { _ => drop t@2 to _; drop t@1 to _; drop t@0 to _; error "ICE: guarded match fell through" }))
fn main() =
  return 5 to t@4; classify(t@4)

