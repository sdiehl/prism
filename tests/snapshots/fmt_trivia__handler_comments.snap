---
source: tests/formatter/fmt_trivia.rs
expression: "fmt(\"effect State\\n\\\n     \\x20 get() : Int\\n\\\n     \\x20 put(Int) : Unit\\n\\\n     \\n\\\n     fn run() : Int ! {State} =\\n\\\n     \\x20 -- install the handler\\n\\\n     \\x20 with handler\\n\\\n     \\x20   -- read the cell\\n\\\n     \\x20   get() resume k => k(42)\\n\\\n     \\x20   -- write the cell\\n\\\n     \\x20   put(v) resume k => k(())\\n\\\n     \\x20 -- after the handler is in scope\\n\\\n     \\x20 let a = get()\\n\\\n     \\x20 a\\n\")"
---
effect State
  get() : Int
  put(Int) : Unit

fn run() : Int ! {State} =
  -- install the handler
  with handler
    -- read the cell
    get() resume k => k(42)
    -- write the cell
    put(v) resume k => k(())
  -- after the handler is in scope
  let a = get()
  a
