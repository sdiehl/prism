== core (cbpv) ==
fn fact(n) =
  return n to t@0; return 0 to t@1; t@0 == t@1 to t@7; if t@7 then (return 1) else (return n to t@5; return n to t@2; return 1 to t@3; t@2 - t@3 to t@4; fact(t@4) to t@6; t@5 * t@6)
fn main() =
  return 5 to t@8; fact(t@8) to r; return r to t@9; print t@9 to t@10; print_nl to u; return r

== fbip (rc) ==
fn fact(n) =
  dup n to _; return n to t@0; return 0 to t@1; t@0 == t@1 to t@7; if t@7 then (drop t@7 to _; drop n to _; return 1) else (drop t@7 to _; dup n to _; return n to t@5; return n to t@2; return 1 to t@3; t@2 - t@3 to t@4; fact(t@4) to t@6; t@5 * t@6)
fn main() =
  return 5 to t@8; fact(t@8) to r; dup r to _; return r to t@9; print t@9 to t@10; drop t@10 to _; print_nl to u; drop u to _; return r

