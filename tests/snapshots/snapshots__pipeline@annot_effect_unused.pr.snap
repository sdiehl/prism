== types ==
h : () -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn h() =
  return 1
fn main() =
  handle { h() } with { get(u, k) => return 0 to t@0; return k to t@1; (force t@1)(t@0), return x => return x } to t@2; print t@2 to t@3; print_nl

== fbip (rc) ==
fn h() =
  return 1
fn main() =
  handle { h() } with { get(u, k) => drop u to _; return 0 to t@0; return k to t@1; (force t@1)(t@0), return x => return x } to t@2; print t@2 to t@3; drop t@3 to _; print_nl

