== types ==
tick_region : (Int) -> Int
tick : (Int) -> Int
main : () -> Int

== core (cbpv) ==
fn tick_region(base) =
  return base to t@0
  return base to t@1
  t@0 + t@1
fn tick(n) =
  return n to t@2
  return 1 to t@3
  t@2 + t@3 to base
  return base to t@4
  tick_region(t@4)
fn main() =
  return 20 to t@5
  tick(t@5)

== fbip (rc) ==
fn tick_region(base) =
  dup base
  return base to t@0
  return base to t@1
  t@0 + t@1
fn tick(n) =
  return n to t@2
  return 1 to t@3
  t@2 + t@3 to base
  return base to t@4
  tick_region(t@4)
fn main() =
  return 20 to t@5
  tick(t@5)

