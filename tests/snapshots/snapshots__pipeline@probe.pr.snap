main : () -> Unit ! {IO}

== core (cbpv) ==
fn main() =
  return "trace" to t@0
  probe_enabled(t@0) to t@3
  if t@3 then
    return 1 to t@1
    print t@1 to t@2
    print_nl
  else
    return ()

== fbip (rc) ==
fn main() =
  return "trace" to t@0
  probe_enabled(t@0) to t@3
  if t@3 then
    drop t@3
    return 1 to t@1
    print t@1 to t@2
    drop t@2
    print_nl
  else
    drop t@3
    return ()

