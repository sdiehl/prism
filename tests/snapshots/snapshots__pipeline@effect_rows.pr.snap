== types ==
risky : (Int) -> Int ! {Exn}
safe : (Int) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn risky(x) =
  return x to t@0; return 0 to t@1; t@0 == t@1 to t@3; if t@3 then (return 99 to t@2; do raise(t@2)) else (return x)
fn safe(x) =
  handle { return x to t@4; risky(t@4) } with { raise(v, k) => return 0 to t@5; return v to t@6; t@5 - t@6, return r => return r }
fn main() =
  return 0 to t@7; safe(t@7) to t@9; return 7 to t@8; safe(t@8) to t@10; t@9 + t@10 to t@11; print t@11 to t@12; print_nl

== fbip (rc) ==
fn risky(x) =
  dup x to _; return x to t@0; return 0 to t@1; t@0 == t@1 to t@3; if t@3 then (drop x to _; drop t@3 to _; return 99 to t@2; do raise(t@2)) else (drop t@3 to _; return x)
fn safe(x) =
  handle { return x to t@4; risky(t@4) } with { raise(v, k) => return 0 to t@5; return v to t@6; t@5 - t@6, return r => return r }
fn main() =
  return 0 to t@7; safe(t@7) to t@9; return 7 to t@8; safe(t@8) to t@10; t@9 + t@10 to t@11; print t@11 to t@12; drop t@12 to _; print_nl

