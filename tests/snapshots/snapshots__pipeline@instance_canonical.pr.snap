main : () -> Int

== core (cbpv) ==
fn main() =
  return 1 to t@0; return 2 to t@1; i@ordInt@cmp(t@0, t@1)
fn i@ordInt@cmp(x, y) =
  return x to t@2; return y to t@3; t@2 < t@3 to t@6; if t@6 then (return 0 to t@4; return 1 to t@5; t@4 - t@5) else (return 1)
fn ordInt() =
  return _DOrd(thunk { \_p0 _p1. i@ordInt@cmp(_p0, _p1) })
fn i@ordRev@cmp(x, y) =
  return x to t@7; return y to t@8; t@7 < t@8 to t@11; if t@11 then (return 1) else (return 0 to t@9; return 1 to t@10; t@9 - t@10)
fn ordRev() =
  return _DOrd(thunk { \_p0 _p1. i@ordRev@cmp(_p0, _p1) })

== fbip (rc) ==
fn main() =
  return 1 to t@0; return 2 to t@1; i@ordInt@cmp(t@0, t@1)
fn i@ordInt@cmp(x, y) =
  return x to t@2; return y to t@3; t@2 < t@3 to t@6; if t@6 then (drop t@6 to _; return 0 to t@4; return 1 to t@5; t@4 - t@5) else (drop t@6 to _; return 1)
fn ordInt() =
  return _DOrd(thunk { \_p0 _p1. i@ordInt@cmp(_p0, _p1) })
fn i@ordRev@cmp(x, y) =
  return x to t@7; return y to t@8; t@7 < t@8 to t@11; if t@11 then (drop t@11 to _; return 1) else (drop t@11 to _; return 0 to t@9; return 1 to t@10; t@9 - t@10)
fn ordRev() =
  return _DOrd(thunk { \_p0 _p1. i@ordRev@cmp(_p0, _p1) })

