  ret i64 %t0
}

define i64 @prism_i.ordInt.cmp(i64 %a0, i64 %a1) {
entry:
  %t0 = and i64 %a0, %a1
  %t1 = and i64 %t0, 1
  %t2 = icmp eq i64 %t1, 1
  br i1 %t2, label %b0, label %b1

b0:                                               ; preds = %entry
  %t3 = icmp slt i64 %a0, %a1
  %t4 = zext i1 %t3 to i64
  %t5 = shl i64 %t4, 1
  %t6 = or i64 %t5, 1
  br label %b2

b1:                                               ; preds = %entry
  %t7 = call i64 @prism_rt_int_cmp(i64 %a0, i64 %a1)
  %t8 = icmp slt i64 %t7, 0
  %t9 = zext i1 %t8 to i64
  %t10 = shl i64 %t9, 1
  %t11 = or i64 %t10, 1
  br label %b2

b2:                                               ; preds = %b1, %b0
  %t12 = phi i64 [ %t6, %b0 ], [ %t11, %b1 ]
  call void @prism_rc_dec(i64 %a0)
  call void @prism_rc_dec(i64 %a1)
  %t13 = icmp ne i64 %t12, 1
  br i1 %t13, label %b3, label %b4

b3:                                               ; preds = %b2
  call void @prism_rc_dec(i64 %t12)
  br i1 true, label %b5, label %b6

b4:                                               ; preds = %b2
  call void @prism_rc_dec(i64 %t12)
  ret i64 3

b5:                                               ; preds = %b3
  br i1 true, label %b8, label %b6

b6:                                               ; preds = %b5, %b3
  %t25 = call i64 @prism_rt_int_sub(i64 1, i64 3)
  br label %b7

b8:                                               ; preds = %b5
  br label %b7

b7:                                               ; preds = %b6, %b8
  %t26 = phi i64 [ -1, %b8 ], [ %t25, %b6 ]
  call void @prism_rc_dec(i64 1)
  call void @prism_rc_dec(i64 3)
  ret i64 %t26
}

