fn main() =
  return 0.1 to t@0; return 0.2 to t@1; t@0 +. t@1 to t@2; printf t@2 to t@3; print_nl to _; return 10 to t@4; return 3 to t@5; t@4 /. t@5 to t@6; printf t@6 to t@7; print_nl to _; return 100 to t@8; return 1 to t@9; t@8 *. t@9 to t@10; printf t@10 to t@11; print_nl to _; return 10000000000000000 to t@12; printf t@12 to t@13; print_nl to _; return 0.00001 to t@14; printf t@14 to t@15; print_nl to _; return 0 to t@16; return 2.5 to t@17; t@16 -. t@17 to t@18; printf t@18 to t@19; print_nl

