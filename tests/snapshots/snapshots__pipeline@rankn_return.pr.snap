== types ==
mkid : () -> forall a. (a) -> a
main : () -> Unit ! {IO}

== core (cbpv) ==
fn mkid() =
  return thunk { \x. return x }
fn main() =
  return 7 to t@0; mkid() to t@1; (force t@1)(t@0) to t@2; print t@2 to t@3; print_nl

== fbip (rc) ==
fn mkid() =
  return thunk { \x. return x }
fn main() =
  return 7 to t@0; mkid() to t@1; (force t@1)(t@0) to t@2; print t@2 to t@3; drop t@3 to _; print_nl

