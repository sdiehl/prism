== types ==
pick : (forall a. (a) -> a) -> Int
relay : (forall a. (a) -> a) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn pick(g) =
  return true to t@0; return g to t@1; (force t@1)(t@0) to t@6; if t@6 then (return 10 to t@2; return g to t@3; (force t@3)(t@2)) else (return 20 to t@4; return g to t@5; (force t@5)(t@4))
fn relay(g) =
  return g to t@7; pick(t@7)
fn main() =
  return thunk { \x. return x } to t@8; relay(t@8) to t@9; print t@9 to t@10; print_nl

== fbip (rc) ==
fn pick(g) =
  dup g to _; return true to t@0; return g to t@1; (force t@1)(t@0) to t@6; if t@6 then (drop t@6 to _; return 10 to t@2; return g to t@3; (force t@3)(t@2)) else (drop t@6 to _; return 20 to t@4; return g to t@5; (force t@5)(t@4))
fn relay(g) =
  return g to t@7; pick(t@7)
fn main() =
  return thunk { \x. return x } to t@8; relay(t@8) to t@9; print t@9 to t@10; drop t@10 to _; print_nl

== llvm ==
; ModuleID = 'prism'
source_filename = "prism"

define i64 @prism_main() {
entry:
  %t0 = call ptr @prism_alloc(i64 0)
  %0 = ptrtoint ptr %t0 to i64
  %1 = add i64 %0, 8
  %t1 = inttoptr i64 %1 to ptr
  store i64 0, ptr %t1, align 8
  %t2 = ptrtoint ptr %t0 to i64
  call void @prism_rc_inc(i64 %t2)
  %t4 = call i64 @prism_apply_1(i64 %t2, i64 3)
  call void @prism_rc_dec(i64 %t2)
  %t5 = icmp ne i64 %t4, 1
  br i1 %t5, label %b0, label %b1

b0:                                               ; preds = %entry
  call void @prism_rc_dec(i64 %t4)
  %t7 = call i64 @prism_apply_1(i64 %t2, i64 21)
  call void @prism_rc_dec(i64 %t2)
  br label %b2

b1:                                               ; preds = %entry
  call void @prism_rc_dec(i64 %t4)
  %t9 = call i64 @prism_apply_1(i64 %t2, i64 41)
  call void @prism_rc_dec(i64 %t2)
  br label %b2

b2:                                               ; preds = %b1, %b0
  %t10 = phi i64 [ %t7, %b0 ], [ %t9, %b1 ]
  call void @prism_print_int(i64 %t10)
  call void @prism_rc_dec(i64 %t10)
  call void @prism_rc_dec(i64 0)
  call void @prism_print_nl()
  ret i64 0
}

declare ptr @prism_alloc(i64)

declare void @prism_rc_inc(i64)

define i64 @prism_apply_1(i64 %_clos, i64 %_a0) {
entry:
  %_cp = inttoptr i64 %_clos to ptr
  %0 = ptrtoint ptr %_cp to i64
  %1 = add i64 %0, 8
  %_tp = inttoptr i64 %1 to ptr
  %_tag = load i64, ptr %_tp, align 8
  switch i64 %_tag, label %_dead [
    i64 0, label %_lam0
  ]

_lam0:                                            ; preds = %entry
  %_r0 = call i64 @prism_lam_0(i64 %_a0)
  br label %_merge

_dead:                                            ; preds = %entry
  call void @prism_apply_error()
  unreachable

_merge:                                           ; preds = %_lam0
  %_result = phi i64 [ %_r0, %_lam0 ]
  ret i64 %_result
}

declare void @prism_rc_dec(i64)

declare void @prism_print_int(i64)

declare void @prism_print_nl()

define i64 @prism_lam_0(i64 %_p0) {
entry:
  ret i64 %_p0
}

declare void @prism_apply_error()

