== types ==
pick : (forall a. (a) -> a) -> Int
relay : (forall a. (a) -> a) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn pick(g) =
  return true to t@0
  return g to t@1
  (force t@1)(t@0) to t@6
  if t@6 then
    return 10 to t@2
    return g to t@3
    (force t@3)(t@2)
  else
    return 20 to t@4
    return g to t@5
    (force t@5)(t@4)
fn relay(g) =
  return g to t@7
  pick(t@7)
fn main() =
  return thunk { \x. return x } to t@8
  relay(t@8) to t@9
  print t@9 to t@10
  print_nl

== fbip (rc) ==
fn pick(g) =
  dup g
  return true to t@0
  return g to t@1
  (force t@1)(t@0) to t@6
  if t@6 then
    drop t@6
    return 10 to t@2
    return g to t@3
    (force t@3)(t@2)
  else
    drop t@6
    return 20 to t@4
    return g to t@5
    (force t@5)(t@4)
fn relay(g) =
  return g to t@7
  pick(t@7)
fn main() =
  return thunk { \x. return x } to t@8
  relay(t@8) to t@9
  print t@9 to t@10
  drop t@10
  print_nl

