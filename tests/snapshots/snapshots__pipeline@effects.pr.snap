== types ==
catch_exn : () -> Int
ask_example : () -> Int
state_example : () -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn catch_exn() =
  handle
    return 42 to t@0
    do raise(t@0)
  with
    raise(v, k) =>
      return v
    return r =>
      return r
fn ask_example() =
  handle
    do ask()
  with
    ask(k) =>
      return 99 to t@1
      return k to t@2
      (force t@2)(t@1)
    return r =>
      return r
fn state_example() =
  handle
    do get() to a
    return a to t@3
    return 1 to t@4
    t@3 + t@4 to t@5
    do put(t@5)
    do get()
  with
    get(k) =>
      return 10 to t@6
      return k to t@7
      (force t@7)(t@6)
    put(v, k) =>
      return () to t@8
      return k to t@9
      (force t@9)(t@8)
    return r =>
      return r
fn main() =
  catch_exn() to a
  ask_example() to b
  state_example() to c
  return a to t@10
  return b to t@11
  t@10 + t@11 to t@12
  return c to t@13
  t@12 + t@13 to t@14
  print t@14 to t@15
  print_nl

== fbip (rc) ==
fn catch_exn() =
  handle
    return 42 to t@0
    do raise(t@0)
  with
    raise(v, k) =>
      return v
    return r =>
      return r
fn ask_example() =
  handle
    do ask()
  with
    ask(k) =>
      return 99 to t@1
      return k to t@2
      (force t@2)(t@1)
    return r =>
      return r
fn state_example() =
  handle
    do get() to a
    return a to t@3
    return 1 to t@4
    t@3 + t@4 to t@5
    do put(t@5)
    drop _
    do get()
  with
    get(k) =>
      return 10 to t@6
      return k to t@7
      (force t@7)(t@6)
    put(v, k) =>
      drop v
      return () to t@8
      return k to t@9
      (force t@9)(t@8)
    return r =>
      return r
fn main() =
  catch_exn() to a
  ask_example() to b
  state_example() to c
  return a to t@10
  return b to t@11
  t@10 + t@11 to t@12
  return c to t@13
  t@12 + t@13 to t@14
  print t@14 to t@15
  drop t@15
  print_nl

