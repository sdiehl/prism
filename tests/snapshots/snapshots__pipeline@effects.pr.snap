== types ==
catch_exn : () -> Int
ask_example : () -> Int
state_example : () -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn catch_exn() =
  handle { return 42 to t@0; do raise(t@0) } with { raise(v, k) => return v, return r => return r }
fn ask_example() =
  handle { return () to t@1; do ask(t@1) } with { ask(v, k) => return 99 to t@2; return k to t@3; (force t@3)(t@2), return r => return r }
fn state_example() =
  handle { return () to t@4; do get(t@4) to a; return a to t@5; return 1 to t@6; t@5 + t@6 to t@7; do put(t@7) to _; return () to t@8; do get(t@8) } with { get(v, k) => return 10 to t@9; return k to t@10; (force t@10)(t@9), put(v, k) => return () to t@11; return k to t@12; (force t@12)(t@11), return r => return r }
fn main() =
  catch_exn() to a; ask_example() to b; state_example() to c; return a to t@13; return b to t@14; t@13 + t@14 to t@15; return c to t@16; t@15 + t@16 to t@17; print t@17 to t@18; print_nl

== fbip (rc) ==
fn catch_exn() =
  handle { return 42 to t@0; do raise(t@0) } with { raise(v, k) => return v, return r => return r }
fn ask_example() =
  handle { return () to t@1; do ask(t@1) } with { ask(v, k) => drop v to _; return 99 to t@2; return k to t@3; (force t@3)(t@2), return r => return r }
fn state_example() =
  handle { return () to t@4; do get(t@4) to a; return a to t@5; return 1 to t@6; t@5 + t@6 to t@7; do put(t@7) to _; drop _ to _; return () to t@8; do get(t@8) } with { get(v, k) => drop v to _; return 10 to t@9; return k to t@10; (force t@10)(t@9), put(v, k) => drop v to _; return () to t@11; return k to t@12; (force t@12)(t@11), return r => return r }
fn main() =
  catch_exn() to a; ask_example() to b; state_example() to c; return a to t@13; return b to t@14; t@13 + t@14 to t@15; return c to t@16; t@15 + t@16 to t@17; print t@17 to t@18; drop t@18 to _; print_nl

