== types ==
fst : ((Int, Int)) -> Int
quad : (Int) -> ((Int, Int), (Int, Int))
main : () -> Unit ! {IO}

== core (cbpv) ==
fn fst(p) =
  return p to t@0
  case t@0 of
    (a, b) =>
      return a
fn quad(x) =
  return x to t@1
  return x to t@2
  return (t@1, t@2) to t@3
  return x to t@4
  return x to t@5
  return (t@4, t@5) to t@6
  return (t@3, t@6)
fn main() =
  return 3 to t@7
  quad(t@7) to t@8
  case t@8 of
    (l, r) =>
      return l to t@9
      fst(t@9) to t@10
      print t@10

== fbip (rc) ==
fn fst(p) =
  return p to t@0
  case t@0 of
    (a, b) =>
      dup a
      drop t@0
      return a
fn quad(x) =
  dup x
  dup x
  return x to t@1
  return x to t@2
  return (t@1, t@2) to t@3
  dup x
  return x to t@4
  return x to t@5
  return (t@4, t@5) to t@6
  return (t@3, t@6)
fn main() =
  return 3 to t@7
  quad(t@7) to t@8
  case t@8 of
    (l, r) =>
      dup l
      drop t@8
      return l to t@9
      fst(t@9) to t@10
      print t@10

