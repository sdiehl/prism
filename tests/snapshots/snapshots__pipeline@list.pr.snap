== types ==
length : forall a. (List(a)) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn length(xs) =
  return xs to t@0
  case t@0 of
    Nil =>
      return 0
    Cons(x, rest) =>
      return 1 to t@2
      return rest to t@1
      length(t@1) to t@3
      t@2 + t@3
fn main() =
  return 1 to t@4
  return 2 to t@5
  return 3 to t@6
  return Nil to t@7
  return Cons(t@6, t@7) to t@8
  return Cons(t@5, t@8) to t@9
  return Cons(t@4, t@9) to t@10
  length(t@10) to t@11
  print t@11 to t@12
  print_nl

== fbip (rc) ==
fn length(xs) =
  return xs to t@0
  case t@0 of
    Nil =>
      drop t@0
      return 0
    Cons(x, rest) =>
      dup rest
      drop t@0
      return 1 to t@2
      return rest to t@1
      length(t@1) to t@3
      t@2 + t@3
fn main() =
  return 1 to t@4
  return 2 to t@5
  return 3 to t@6
  return Nil to t@7
  return Cons(t@6, t@7) to t@8
  return Cons(t@5, t@8) to t@9
  return Cons(t@4, t@9) to t@10
  length(t@10) to t@11
  print t@11 to t@12
  drop t@12
  print_nl

