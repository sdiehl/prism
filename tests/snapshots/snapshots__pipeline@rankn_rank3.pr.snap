== types ==
rank3 : (forall a. (forall b. (b) -> b, a) -> a) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn rank3(g) =
  return thunk { \x. return x } to t@0; return 0 to t@1; return g to t@2; (force t@2)(t@0, t@1)
fn main() =
  return thunk { \f y. return y to t@3; return f to t@4; (force t@4)(t@3) } to t@5; rank3(t@5) to t@6; print t@6 to t@7; print_nl

== fbip (rc) ==
fn rank3(g) =
  return thunk { \x. return x } to t@0; return 0 to t@1; return g to t@2; (force t@2)(t@0, t@1)
fn main() =
  return thunk { \f y. return y to t@3; return f to t@4; (force t@4)(t@3) } to t@5; rank3(t@5) to t@6; print t@6 to t@7; drop t@7 to _; print_nl

