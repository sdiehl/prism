== types ==
useit : (Wrap) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn useit(w) =
  return w to t@0; case t@0 { Wrap(f) => return 42 to t@1; return f to t@2; (force t@2)(t@1) }
fn main() =
  return thunk { \x. return x } to t@3; return Wrap(t@3) to t@4; useit(t@4) to t@5; print t@5 to t@6; print_nl

== fbip (rc) ==
fn useit(w) =
  return w to t@0; case t@0 { Wrap(f) => dup f to _; drop t@0 to _; return 42 to t@1; return f to t@2; (force t@2)(t@1) }
fn main() =
  return thunk { \x. return x } to t@3; return Wrap(t@3) to t@4; useit(t@4) to t@5; print t@5 to t@6; drop t@6 to _; print_nl

