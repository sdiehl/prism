== types ==
bump : (Pair, Int) -> Pair
main : () -> Unit ! {IO}

== core (cbpv) ==
fn bump(p, _reuse_p) =
  return p to t@0; case t@0 { Pair(a, b) => return a to t@1; return _reuse_p to t@2; t@1 + t@2 to t@3; return b to t@4; return Pair(t@3, t@4) }
fn main() =
  return 1 to t@5; return 2 to t@6; return Pair(t@5, t@6) to t@7; return 10 to t@8; bump(t@7, t@8) to t@9; case t@9 { Pair(x, y) => return x to t@10; return y to t@11; t@10 + t@11 to t@12; print t@12 to t@13; print_nl }

== fbip (rc) ==
fn bump(p, _reuse_p) =
  return p to t@0; case t@0 { Pair(a, b) => dup a to _; dup b to _; reuse_token t@0 to reuse#t@0; return a to t@1; return _reuse_p to t@2; t@1 + t@2 to t@3; return b to t@4; reuse reuse#t@0 as Pair(t@3, t@4) }
fn main() =
  return 1 to t@5; return 2 to t@6; return Pair(t@5, t@6) to t@7; return 10 to t@8; bump(t@7, t@8) to t@9; case t@9 { Pair(x, y) => dup x to _; dup y to _; drop t@9 to _; return x to t@10; return y to t@11; t@10 + t@11 to t@12; print t@12 to t@13; drop t@13 to _; print_nl }

