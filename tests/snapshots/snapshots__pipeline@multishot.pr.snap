== types ==
collect_bools : () -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn collect_bools() =
  handle { return 1 to t@0; do yield(t@0) to a; return 2 to t@1; do yield(t@1) to b; return 3 to t@2; do yield(t@2) to c; return a to t@5; if t@5 then (return b to t@4; if t@4 then (return c to t@3; if t@3 then (return 7) else (return 6)) else (return 5)) else (return 4) } with { yield(v, k) => return v to t@6; return 1 to t@7; t@6 > t@7 to t@8; return k to t@9; (force t@9)(t@8), return r => return r }
fn main() =
  collect_bools() to t@10; print t@10 to t@11; print_nl

== fbip (rc) ==
fn collect_bools() =
  handle { return 1 to t@0; do yield(t@0) to a; return 2 to t@1; do yield(t@1) to b; return 3 to t@2; do yield(t@2) to c; return a to t@5; if t@5 then (drop t@5 to _; return b to t@4; if t@4 then (drop t@4 to _; return c to t@3; if t@3 then (drop t@3 to _; return 7) else (drop t@3 to _; return 6)) else (drop t@4 to _; drop c to _; return 5)) else (drop t@5 to _; drop c to _; drop b to _; return 4) } with { yield(v, k) => return v to t@6; return 1 to t@7; t@6 > t@7 to t@8; return k to t@9; (force t@9)(t@8), return r => return r }
fn main() =
  collect_bools() to t@10; print t@10 to t@11; drop t@11 to _; print_nl

