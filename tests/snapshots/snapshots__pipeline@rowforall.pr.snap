== types ==
apply_io : ((Int) -> Int ! {IO}) -> Int ! {IO}
use_pure : (forall e. (Int) -> Int ! {e}) -> Int ! {IO}
main : () -> Unit ! {IO}

== core (cbpv) ==
fn apply_io(g) =
  return 1 to t@0
  return g to t@1
  (force t@1)(t@0)
fn use_pure(h) =
  return h to t@2
  apply_io(t@2)
fn main() =
  thunk { \x.
    return x to t@3
    return 41 to t@4
    t@3 + t@4
  } to t@5
  use_pure(t@5) to t@6
  print t@6 to t@7
  print_nl

== fbip (rc) ==
fn apply_io(g) =
  return 1 to t@0
  return g to t@1
  (force t@1)(t@0)
fn use_pure(h) =
  return h to t@2
  apply_io(t@2)
fn main() =
  thunk { \x.
    return x to t@3
    return 41 to t@4
    t@3 + t@4
  } to t@5
  use_pure(t@5) to t@6
  print t@6 to t@7
  drop t@7
  print_nl

