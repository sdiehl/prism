== types ==
get : forall a. (a, Option(a)) -> a
main : () -> Unit ! {IO}

== core (cbpv) ==
fn get(d, o) =
  return o to t@0; case t@0 { None => return d | Some(x) => return x }
fn main() =
  return 0 to t@1; return 42 to t@2; return Some(t@2) to t@3; get(t@1, t@3) to t@4; print t@4 to t@5; print_nl

== fbip (rc) ==
fn get(d, o) =
  return o to t@0; case t@0 { None => drop t@0 to _; return d | Some(x) => dup x to _; drop t@0 to _; drop d to _; return x }
fn main() =
  return 0 to t@1; return 42 to t@2; return Some(t@2) to t@3; get(t@1, t@3) to t@4; print t@4 to t@5; drop t@5 to _; print_nl

