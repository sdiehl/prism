== core (cbpv) ==
fn get(d, o) =
  return o to t@0
  case t@0 of
    None =>
      return d
    Some(x) =>
      return x
fn main() =
  return 0 to t@1
  return 42 to t@2
  return Some(t@2) to t@3
  get(t@1, t@3) to t@4
  print t@4 to t@5
  print_nl

== fbip (rc) ==
fn get(d, o) =
  return o to t@0
  case t@0 of
    None =>
      drop t@0
      return d
    Some(x) =>
      dup x
      drop t@0
      drop d
      return x
fn main() =
  return 0 to t@1
  return 42 to t@2
  return Some(t@2) to t@3
  get(t@1, t@3) to t@4
  print t@4 to t@5
  drop t@5
  print_nl

