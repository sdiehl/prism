== types ==
czero : () -> CNat
csucc : (CNat) -> CNat
toInt : (CNat) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn czero() =
  return thunk { \f x. return x } to t@0; return CNat(t@0)
fn csucc(n) =
  return n to t@1; case t@1 { CNat(g) => return thunk { \f x. return f to t@2; return x to t@3; return g to t@4; (force t@4)(t@2, t@3) to t@5; return f to t@6; (force t@6)(t@5) } to t@7; return CNat(t@7) }
fn toInt(n) =
  return n to t@8; case t@8 { CNat(g) => return thunk { \k. return k to t@9; return 1 to t@10; t@9 + t@10 } to t@11; return 0 to t@12; return g to t@13; (force t@13)(t@11, t@12) }
fn main() =
  czero() to t@14; csucc(t@14) to t@15; csucc(t@15) to t@16; csucc(t@16) to t@17; toInt(t@17) to t@18; print t@18 to t@19; print_nl

== fbip (rc) ==
fn czero() =
  return thunk { \f x. drop f to _; return x } to t@0; return CNat(t@0)
fn csucc(n) =
  return n to t@1; case t@1 { CNat(g) => dup g to _; reuse_token t@1 to reuse#t@1; return thunk { \f x. dup f to _; return f to t@2; return x to t@3; dup g to _; return g to t@4; (force t@4)(t@2, t@3) to t@5; return f to t@6; (force t@6)(t@5) } to t@7; reuse reuse#t@1 as CNat(t@7) }
fn toInt(n) =
  return n to t@8; case t@8 { CNat(g) => dup g to _; drop t@8 to _; return thunk { \k. return k to t@9; return 1 to t@10; t@9 + t@10 } to t@11; return 0 to t@12; return g to t@13; (force t@13)(t@11, t@12) }
fn main() =
  czero() to t@14; csucc(t@14) to t@15; csucc(t@15) to t@16; csucc(t@16) to t@17; toInt(t@17) to t@18; print t@18 to t@19; drop t@19 to _; print_nl

