== types ==
apply : ((Int) -> Int ! {Exn}, Int) -> Int ! {Exn}
risky : (Int) -> Int ! {Exn}
main : () -> Int

== core (cbpv) ==
fn apply(f, x) =
  return x to t@0; return f to t@1; (force t@1)(t@0)
fn risky(x) =
  return x to t@2; return 0 to t@3; t@2 == t@3 to t@5; if t@5 then (return 1 to t@4; do raise(t@4)) else (return x)
fn main() =
  handle { return thunk { \_p0. risky(_p0) } to t@6; return 0 to t@7; apply(t@6, t@7) } with { raise(v, k) => return 0 to t@8; return v to t@9; t@8 - t@9, return r => return r }

== fbip (rc) ==
fn apply(f, x) =
  return x to t@0; return f to t@1; (force t@1)(t@0)
fn risky(x) =
  dup x to _; return x to t@2; return 0 to t@3; t@2 == t@3 to t@5; if t@5 then (drop x to _; drop t@5 to _; return 1 to t@4; do raise(t@4)) else (drop t@5 to _; return x)
fn main() =
  handle { return thunk { \_p0. risky(_p0) } to t@6; return 0 to t@7; apply(t@6, t@7) } with { raise(v, k) => return 0 to t@8; return v to t@9; t@8 - t@9, return r => return r }

