== types ==
twice : forall e0 a. ((a) -> a ! {e0}, a) -> a ! {e0}
inc : (Int) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn twice(f, x) =
  return x to t@0
  return f to t@1
  (force t@1)(t@0) to t@2
  return f to t@3
  (force t@3)(t@2)
fn inc(x) =
  return x to t@4
  return 1 to t@5
  t@4 + t@5
fn main() =
  return thunk { \_p0. inc(_p0) } to t@6
  return 0 to t@7
  twice(t@6, t@7) to t@8
  print t@8 to t@9
  print_nl

== fbip (rc) ==
fn twice(f, x) =
  dup f
  return x to t@0
  return f to t@1
  (force t@1)(t@0) to t@2
  return f to t@3
  (force t@3)(t@2)
fn inc(x) =
  return x to t@4
  return 1 to t@5
  t@4 + t@5
fn main() =
  return thunk { \_p0. inc(_p0) } to t@6
  return 0 to t@7
  twice(t@6, t@7) to t@8
  print t@8 to t@9
  drop t@9
  print_nl

