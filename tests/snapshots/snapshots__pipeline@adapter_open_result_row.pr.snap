== types ==
adapt_v1_to_v2 : forall e0 a. (() -> a ! {KvV1, KvV2, e0}) -> a ! {KvV2, e0}

== core (cbpv) ==
fn adapt_v1_to_v2(action) =
  handle
    return action to t@0
    (force t@0)()
  with
    get_v1(key, k) =>
      return key to t@1
      do get_v2(t@1) to t@2
      return k to t@3
      (force t@3)(t@2)
    put_v1(key, value, k) =>
      return key to t@4
      return value to t@5
      do put_v2(t@4, t@5)
      return () to t@6
      return k to t@7
      (force t@7)(t@6)
    return r =>
      return r

== fbip (rc) ==
fn adapt_v1_to_v2(action) =
  handle
    return action to t@0
    (force t@0)()
  with
    get_v1(key, k) =>
      return key to t@1
      do get_v2(t@1) to t@2
      return k to t@3
      (force t@3)(t@2)
    put_v1(key, value, k) =>
      return key to t@4
      return value to t@5
      do put_v2(t@4, t@5)
      drop _
      return () to t@6
      return k to t@7
      (force t@7)(t@6)
    return r =>
      return r

