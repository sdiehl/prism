== types ==
pick : (forall a b. (a, b) -> a) -> Int
main : () -> Unit ! {IO}

== core (cbpv) ==
fn pick(g) =
  return 1 to t@0
  return true to t@1
  return g to t@2
  (force t@2)(t@0, t@1) to t@3
  return "x" to t@4
  return g to t@5
  (force t@5)(t@3, t@4)
fn main() =
  return thunk { \x y. return x } to t@6
  pick(t@6) to t@7
  return 2 to t@8
  return thunk { \x y. return x } to t@9
  (force t@9)(t@7, t@8) to t@10
  print t@10 to t@11
  print_nl

== fbip (rc) ==
fn pick(g) =
  dup g
  return 1 to t@0
  return true to t@1
  return g to t@2
  (force t@2)(t@0, t@1) to t@3
  return "x" to t@4
  return g to t@5
  (force t@5)(t@3, t@4)
fn main() =
  thunk { \x y.
    drop y
    return x
  } to t@6
  pick(t@6) to t@7
  return 2 to t@8
  thunk { \x y.
    drop y
    return x
  } to t@9
  (force t@9)(t@7, t@8) to t@10
  print t@10 to t@11
  drop t@11
  print_nl

