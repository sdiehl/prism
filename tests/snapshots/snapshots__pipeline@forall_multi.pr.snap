  call void @prism_rc_dec(i64 %t4)
  %t12 = call ptr @prism_alloc(i64 0)
  %t13 = getelementptr inbounds i8, ptr %t12, i64 8
  store i64 1, ptr %t13, align 8
  %t15 = ptrtoint ptr %t12 to i64
  %t17 = call i64 @prism_apply_2(i64 %t15, i64 %t10, i64 5)
