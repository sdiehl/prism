== types ==
relabel : (Tree) -> Tree

== core (cbpv) ==
fn relabel(t) =
  return t to t@0; case t@0 { Leaf => return Leaf | Node(l, x, r) => return l to t@1; relabel(t@1) to t@2; return x to t@3; return x to t@4; t@3 + t@4 to t@5; return r to t@6; relabel(t@6) to t@7; return Node(t@2, t@5, t@7) }

