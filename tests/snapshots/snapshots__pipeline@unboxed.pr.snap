== core (cbpv) ==
fn area(p) =
  return 0
fn point() =
  return 1 to t@0
  return 2 to t@1
  return #(t@0, t@1)
fn main() =
  return 1 to t@2
  return 2 to t@3
  return #(t@2, t@3) to q
  point() to t@4
  case t@4 of
    (t@5, _) =>
      return t@5
  to t@8
  point() to t@6
  case t@6 of
    (_, t@7) =>
      return t@7
  to t@9
  t@8 + t@9

== fbip (rc) ==
fn area(p) =
  drop p
  return 0
fn point() =
  return 1 to t@0
  return 2 to t@1
  return #(t@0, t@1)
fn main() =
  return 1 to t@2
  return 2 to t@3
  return #(t@2, t@3) to q
  drop q
  point() to t@4
  case t@4 of
    (t@5, _) =>
      dup t@5
      drop t@4
      return t@5
  to t@8
  point() to t@6
  case t@6 of
    (_, t@7) =>
      dup t@7
      drop t@6
      return t@7
  to t@9
  t@8 + t@9

