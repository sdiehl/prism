== core (cbpv) ==
fn eqp(x, y) =
  return x to t@0
  return y to t@1
  t@0 == t@1
fn ltp(x, y) =
  return x to t@2
  return y to t@3
  t@2 < t@3
fn main() =
  return 1 to t@4
  return 1 to t@5
  t@4 == t@5 to t@6
  show_bool(t@6) to t@7
  prints t@7 to t@8
  print_nl
  return "a" to t@9
  return "b" to t@10
  str_eq(t@9, t@10) to t@11
  show_bool(t@11) to t@12
  prints t@12 to t@13
  print_nl
  return 1 to t@14
  return 2 to t@15
  t@14 ==. t@15 to t@16
  show_bool(t@16) to t@17
  prints t@17 to t@18
  print_nl
  return 2 to t@19
  return 2 to t@20
  eqp(t@19, t@20) to t@21
  show_bool(t@21) to t@22
  prints t@22 to t@23
  print_nl
  return 1 to t@24
  return 2 to t@25
  ltp(t@24, t@25) to t@26
  show_bool(t@26) to t@27
  prints t@27 to t@28
  print_nl

